{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Hustlify: запуск сервера",
      "program": "${workspaceFolder}/server.js",
      "runtimeExecutable": "node",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Hustlify: watch-режим (авто-рестарт)",
      "program": "${workspaceFolder}/server.js",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch"],
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Hustlify: подключиться к запущенному процессу",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
