# ---- Сервер ----
PORT=3000
# Публичный адрес вашего сайта (для webhook и return_url), без слэша на конце
PUBLIC_URL=https://your-domain.com

# Где хранить data/*.json (товары, заказы, промокоды, новости).
# Оставьте пустым для локального запуска и обычного VPS — будет использована
# папка ./data из проекта. На платформах с эфемерным диском (Render, Railway)
# укажите путь к подключённому persistent disk, например /var/data —
# см. раздел "Деплой на Render.com" в README.
DATA_DIR=

# ---- Админка ----
# Секретный логин/пароль в админку. НЕ храните пароль в открытом виде -
# сгенерируйте хеш командой:  node -e "console.log(require('bcryptjs').hashSync('ваш_пароль', 10))"
ADMIN_LOGIN=admin
ADMIN_PASSWORD_HASH=$2a$10$замените.на.свой.хеш.из.команды.выше
# Случайная длинная строка для подписи сессионных токенов (сгенерируйте свою)
JWT_SECRET=замените_на_случайную_строку_минимум_32_символа

# ---- CryptoBot (https://t.me/CryptoBot -> Crypto Pay -> Create App) ----
CRYPTOBOT_TOKEN=603048:AARtukA87w7qRBATKsI7ARrspFliGA3iZTx
# Валюта инвойса: USDT, TON, BTC, ETH и т.д.
CRYPTOBOT_ASSET=USDT

# Оплата по реквизитам теперь настраивается прямо в админке (вкладка
# "Реквизиты"), а не через .env — ЮKassa больше не используется.

# ---- Telegram-уведомления о заказах ----
# 1) Создайте бота у @BotFather -> /newbot -> скопируйте токен сюда
# 2) Напишите этому боту любое сообщение (просто "привет")
# 3) Откройте в браузере: https://api.telegram.org/bot<ВАШ_ТОКЕН>/getUpdates
#    и найдите там "chat":{"id": ЧИСЛО ...} - это и есть ваш chat_id
# 4) Если получателей несколько - перечислите id через запятую
TELEGRAM_BOT_TOKEN=8818648902:AAFqNgNZFvSdgYOGdZwmA-RnKMrnBqLW_5w
TELEGRAM_ADMIN_CHAT_IDS=5119044165
